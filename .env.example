# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secret credentials.

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=

# Server-side only — NEVER expose to client
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend email API key — SERVER ONLY, never use VITE_ prefix
RESEND_API_KEY=re_your_key_here

# Sentry error monitoring (optional — stub mode without it)
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# PostHog analytics (optional — stub mode without it)
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://app.posthog.com

# Web Push (VAPID) — SERVER ONLY, never use VITE_ prefix
# Generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com
