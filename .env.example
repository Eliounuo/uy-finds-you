# Frontend env (safe to commit only with placeholders)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Resend email API key (optional — without it email service runs in stub mode)
VITE_RESEND_API_KEY=re_your_key_here

# Sentry error monitoring (optional — without it runs in stub mode)
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# PostHog analytics (optional — without it runs in stub mode)
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://app.posthog.com
